{
  "name": "ai-website-guide",
  "version": "1.0.0",
  "private": true,
  "engines": {
    "node": ">=22.13.0"
  },
  "scripts": {
    "prepare:data": "node scripts/sync-public-data.mjs && node scripts/build-offline.mjs",
    "dev": "npm run prepare:data && WRANGLER_LOG_PATH=.wrangler/wrangler.log vinext dev",
    "build": "npm run prepare:data && WRANGLER_LOG_PATH=.wrangler/wrangler.log vinext build",
    "start": "WRANGLER_LOG_PATH=.wrangler/wrangler.log vinext start",
    "test:logic": "node --import tsx --test tests/logic.test.ts",
    "privacy:scan": "node scripts/privacy-scan.mjs",
    "test": "npm run test:logic && npm run build && node --test tests/rendered-html.test.mjs && npm run privacy:scan",
    "skills:update-report": "node scripts/update-skill-metadata.mjs",
    "lint": "eslint . --ignore-pattern dist --ignore-pattern .next",
    "offline": "npm run prepare:data"
  },
  "dependencies": {
    "next": "16.2.6",
    "react": "19.2.6",
    "react-dom": "19.2.6"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "1.37.1",
    "@tailwindcss/postcss": "4.2.1",
    "@types/node": "22.19.19",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.2",
    "@vitejs/plugin-rsc": "0.5.26",
    "esbuild": "0.28.0",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.6",
    "react-server-dom-webpack": "19.2.6",
    "tailwindcss": "4.2.1",
    "tsx": "4.22.1",
    "typescript": "5.9.3",
    "vinext": "0.0.50",
    "vite": "8.0.13",
    "wrangler": "4.92.0"
  },
  "type": "module"
}
